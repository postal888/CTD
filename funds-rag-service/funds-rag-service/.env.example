# OpenAI
OPENAI_API_KEY=sk-...

# PostgreSQL
POSTGRES_USER=rag
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=funds_rag
POSTGRES_HOST=db
POSTGRES_PORT=5432

# RAG Service
RAG_PORT=8100
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
TOP_K=10
# Путь к папке с файлами фондов на хосте (для монтирования в /app/funds_data).
# На Windows укажи абсолютный путь, иначе папка может не находиться:
# FUNDS_HOST_PATH=E:\GIT\CTD\Funds
# Путь к JSONL фондов (по умолчанию funds_clean.jsonl). В Docker задаётся в docker-compose.
# FUNDS_JSONL_PATH=/app/funds_data/funds_clean.jsonl