[Unit]
Description=CrackTheDeck API (FastAPI)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/crackthedeck/crackthedeck-backend/crackthedeck-backend
EnvironmentFile=/var/www/crackthedeck/crackthedeck-backend/crackthedeck-backend/.env
ExecStart=/var/www/crackthedeck/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
