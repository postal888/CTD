OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
MOCK_MODE=false
MAX_FILE_SIZE_MB=50
HOST=0.0.0.0
PORT=8000
# Optional: Poppler (PDF→images). Default: ./poppler-25.12.0/Library/bin
# POPPLER_DIR=
# Optional: LibreOffice (PPTX→PDF). Windows: path to soffice.exe; Linux/Mac: libreoffice
# LIBREOFFICE_CMD=
# Funds RAG service URL for "Find matching funds" (default: http://localhost:8100)
# FUNDS_RAG_URL=http://localhost:8100